{
  "name": "md-editor",
  "productName": "Markdown Editor",
  "private": true,
  "version": "0.1.4",
  "type": "module",
  "scripts": {
    "dev": "npm run build && electron .",
    "build": "vite build",
    "test": "node --test electron/*.test.cjs && node --import tsx --test src/lib/*.test.ts",
    "package": "npm run build && electron-builder --publish never"
  },
  "devDependencies": {
    "@codemirror/commands": "^6.7.1",
    "@codemirror/lang-markdown": "^6.3.1",
    "@codemirror/language": "^6.10.3",
    "@codemirror/state": "^6.4.1",
    "@codemirror/view": "^6.34.1",
    "@fontsource-variable/geist": "^5.3.0",
    "@fontsource-variable/geist-mono": "^5.3.0",
    "@lezer/highlight": "^1.2.1",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@types/markdown-it": "^14.1.2",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "autoprefixer": "^10.4.20",
    "class-variance-authority": "^0.7.0",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.1",
    "dompurify": "^3.1.6",
    "electron": "^31.3.0",
    "electron-builder": "^24.13.3",
    "github-markdown-css": "^5.5.1",
    "lucide-react": "^0.427.0",
    "markdown-it": "^14.1.0",
    "markdown-it-task-lists": "^2.1.1",
    "postcss": "^8.4.41",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.4",
    "tailwind-merge": "^2.5.2",
    "tailwindcss": "^3.4.10",
    "tailwindcss-animate": "^1.0.7",
    "tsx": "^4.8.1",
    "vite": "^5.4.2",
    "yaml": "^2.4.2"
  },
  "description": "A focused desktop Markdown editor with a live side-by-side preview.",
  "author": {
    "name": "Jumballaya"
  },
  "homepage": "https://github.com/Jumballaya/md-editor",
  "repository": {
    "type": "git",
    "url": "https://github.com/Jumballaya/md-editor.git"
  },
  "copyright": "Copyright © 2026 Jumballaya",
  "license": "MIT",
  "main": "electron/main.cjs",
  "build": {
    "appId": "com.jumballaya.mdeditor",
    "productName": "Markdown Editor",
    "directories": {
      "output": "release",
      "buildResources": "build"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ],
    "extraResources": [
      {
        "from": "build/icon.png",
        "to": "icon.png"
      }
    ],
    "mac": {
      "icon": "build/icon.png",
      "target": [
        "dmg",
        "zip"
      ],
      "category": "public.app-category.productivity"
    },
    "win": {
      "icon": "build/icon.png",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "linux": {
      "icon": "build/icon.png",
      "target": [
        "AppImage",
        "deb"
      ],
      "category": "Utility",
      "maintainer": "Jumballaya"
    },
    "publish": {
      "provider": "github",
      "owner": "Jumballaya",
      "repo": "md-editor"
    }
  }
}
